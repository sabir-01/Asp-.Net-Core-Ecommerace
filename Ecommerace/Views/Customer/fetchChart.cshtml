@{
    ViewData["Title"] = "fetchChart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model List<Carts>

<div class="container mt-4">

    <h2 class="text-center mb-4 text-uppercase" style="letter-spacing:2px; ">Your Cart</h2>

    @if (!Model.Any())
    {
        <h4 class="text-center text-danger">Your cart is empty!</h4>
    }
    else
    {
        <div class="card shadow-sm rounded-4 border-0">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>Cart ID</th>
                                <th>Product</th>
                                <th>Image</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Subtotal</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal grandTotal = 0;
                            }
                            @foreach (var item in Model)
                            {
                                decimal price = Convert.ToDecimal(item.products.product_price);
                                decimal subtotal = price * item.product_quantity;
                                grandTotal += subtotal;

                                <tr>
                                    <td>@item.cart_id</td>
                                    <td class="fw-semibold">@item.products.product_name</td>
                                    <td>
                                        <img src="~/product_images/@item.products.product_image"
                                             style="height:60px; width:60px; object-fit:cover;"
                                             class="rounded" />
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center align-items-center gap-1">
                                            <a href="@Url.Action("DecreaseQty","Customer", new { id = item.cart_id })" class="btn btn-sm btn-danger rounded-circle">-</a>
                                            <span class="mx-2 fw-semibold">@item.product_quantity</span>
                                            <a href="@Url.Action("IncreaseQty","Customer", new { id = item.cart_id })" class="btn btn-sm btn-success rounded-circle">+</a>
                                        </div>
                                    </td>
                                    <td>Rs. @price</td>
                                    <td>Rs. @subtotal</td>
                                    <td>@(item.cart_status == 1 ? "Order" : "Pending")</td>
                                    <td>
                                        <a href="@Url.Action("RemoveProduct","Customer", new { id = item.cart_id })" class="btn btn-sm btn-warning rounded-pill px-3">
                                            Remove
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end fw-bold">Grand Total:</td>
                                <td colspan="3" class="fw-bold">Rs. @grandTotal</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Checkout Button -->
                <div class="text-end mt-3">
                    <form method="post" action="@Url.Action("Checkoutinformation","Customer")">
                        <input type="hidden" name="customerId" value="@Model[0].cust_id" />
                        <button type="submit" class="btn btn-warning rounded-pill px-4">
                            <i class="fa-solid fa-credit-card me-1"></i> Checkout
                        </button>
                    </form>
                </div>

            </div>
        </div>
    }
</div>