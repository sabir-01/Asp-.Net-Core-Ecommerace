@model OrderDetails

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white rounded-top-4 text-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Update / Edit Order Details
            </h4>
        </div>

        <div class="card-body">

            <div class="row">
                <div class="col-md-2"></div>

                <div class="col-md-8">

                    <form method="post">

                        <!-- Hidden Primary Key -->
                        <input type="hidden" name="orderDetails_id" value="@Model.orderDetails_id" />

                        <!-- Order ID -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Order ID</label>
                            <input type="number" name="order_id" class="form-control" value="@Model.order_id" readonly />
                        </div>

                        <!-- Product Dropdown -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product</label>
                            @Html.Partial("ProductDropdown", ViewData["products"])
                        </div>

                        <!-- Quantity -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Quantity</label>
                            <input type="number" name="quantity" class="form-control" value="@Model.quantity" />
                        </div>

                        <!-- Price -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Price</label>
                            <input type="number" step="0.01" name="price" class="form-control" value="@Model.price" />
                        </div>

                        <!-- Sub Total -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Sub Total</label>
                            <input type="number" step="0.01" name="sub_total" class="form-control" value="@Model.sub_total" readonly />
                        </div>

                        <!-- Submit Button -->
                        <div class="d-flex gap-2 flex-wrap">
                            <input type="submit" value="Update Order Detail" class="btn btn-primary flex-fill rounded-pill" />
                            <a href="@Url.Action("OrderDetails","Admin")" class="btn btn-warning flex-fill rounded-pill">
                                <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                            </a>
                        </div>

                    </form>

                </div>

                <div class="col-md-2"></div>
            </div>

        </div>

    </div>

</div>