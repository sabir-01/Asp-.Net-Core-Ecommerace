@model List<Catagory>

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                All Category
            </h4>
            <a href="@Url.Action("addCategory","Admin")" class="btn btn-sm btn-light rounded-pill">
                <i class="fa-solid fa-plus me-1"></i> Add New
            </a>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Category Id</th>
                            <th>Category Name</th>
                            <th width="200">Options</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@cat.category_id</td>
                                <td>@cat.category_name</td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a href="@Url.Action("updateCategory","Admin", new { id = cat.category_id })"
                                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="fa-solid fa-pen me-1"></i> Update
                                        </a>

                                        <a href="@Url.Action("deletePermissionCategory","Admin", new { id = cat.category_id })"
                                           class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>