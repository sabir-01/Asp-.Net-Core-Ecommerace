@model Carts

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white rounded-top-4 text-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Update / Edit Cart
            </h4>
        </div>

        <div class="card-body">

            <div class="row">
                <div class="col-md-2"></div>

                <div class="col-md-8">

                    <form method="post">

                        <!-- Hidden Fields -->
                        <input type="hidden" name="cart_id" value="@Model.cart_id" />
                        <input type="hidden" name="prod_id" value="@Model.prod_id" />
                        <input type="hidden" name="cust_id" value="@Model.cust_id" />
                        <input type="hidden" name="product_quantity" value="@Model.product_quantity" />

                        <!-- Cart Status -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Cart Status</label>
                            <select name="cart_status" class="form-select my-3">
                                <option value="1" selected="@(Model.cart_status == 1)">Order</option>
                                <option value="0" selected="@(Model.cart_status == 0)">Pending</option>
                            </select>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 flex-wrap">
                            <input type="submit" value="Update Cart" class="btn btn-primary flex-fill rounded-pill" />
                            <a href="@Url.Action("fetchCart","Admin")" class="btn btn-warning flex-fill rounded-pill">
                                <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                            </a>
                        </div>

                    </form>

                </div>

                <div class="col-md-2"></div>
            </div>

        </div>

    </div>

</div>