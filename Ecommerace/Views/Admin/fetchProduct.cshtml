@model List<Product>

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                All Products
            </h4>
            <a href="@Url.Action("addProduct","Admin")" class="btn btn-sm btn-light rounded-pill">
                <i class="fa-solid fa-plus me-1"></i> Add New
            </a>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th>Product Price</th>
                            <th>Product Image</th>
                            <th width="240">Options</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var prod in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@prod.product_name</td>
                                <td>@prod.product_price</td>
                                <td>
                                    <img src="@Url.Content("~/product_images/" + prod.product_image)"
                                         class="img-fluid rounded shadow-sm"
                                         style="width:60px; height:60px; object-fit:cover;" />
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a href="@Url.Action("productDetails","Admin", new { id = prod.product_id })"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="fa-solid fa-eye me-1"></i> Details
                                        </a>

                                        <a href="@Url.Action("updateProduct","Admin", new { id = prod.product_id })"
                                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="fa-solid fa-pen me-1"></i> Update
                                        </a>

                                        <a href="@Url.Action("deletePermissionProduct","Admin", new { id = prod.product_id })"
                                           class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>