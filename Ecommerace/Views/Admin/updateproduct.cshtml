@model Product

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <!-- Card Header -->
        <div class="card-header bg-primary text-white rounded-top-4 text-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Update / Edit Product
            </h4>
        </div>

        <!-- Card Body -->
        <div class="card-body">

            <div class="row">
                <div class="col-md-2"></div>

                <div class="col-md-8">

                    <!-- Product Details Update Form -->
                    <form method="post">

                        <input type="hidden" name="product_id" value="@Model.product_id" />
                        <input type="hidden" name="product_image" value="@Model.product_image" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product Name</label>
                            <input type="text" name="product_name" class="form-control" value="@Model.product_name" placeholder="Enter Product Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product Price</label>
                            <input type="number" name="product_price" class="form-control" value="@Model.product_price" placeholder="Enter Product Price" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product Description</label>
                            <input type="text" name="product_description" class="form-control" value="@Model.product_description" placeholder="Enter Product Description" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Category</label>
                            @Html.Partial("CategoryDropdown", ViewData["category"])
                        </div>

                        <div class="d-flex gap-2 flex-wrap mb-4">
                            <input type="submit" value="Update Product" class="btn btn-primary flex-fill rounded-pill" />
                            <a href="@Url.Action("fetchproduct","Admin")" class="btn btn-warning flex-fill rounded-pill">
                                <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                            </a>
                        </div>

                    </form>

                    <hr class="my-4" />

                    <!-- Product Image Update Form -->
                    <form method="post" enctype="multipart/form-data">

                        <input type="hidden" name="product_id" value="@Model.product_id" />
                        <input type="hidden" name="product_name" value="@Model.product_name" />
                        <input type="hidden" name="product_price" value="@Model.product_price" />
                        <input type="hidden" name="product_description" value="@Model.product_description" />
                        <input type="hidden" name="cat_id" value="@Model.cat_id" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Change Product Image</label>
                            <input type="file" name="product_image" class="form-control" />
                        </div>

                        <div class="mb-3 text-center">
                            <img src="@Url.Content("~/product_images/" + Model.product_image)"
                                 class="img-fluid shadow-sm rounded my-3"
                                 style="width:250px; height:250px; object-fit:cover;" />
                        </div>

                        <input type="submit" value="Change Product Image" class="btn btn-primary form-control rounded-pill" />

                    </form>

                </div>

                <div class="col-md-2"></div>
            </div>

        </div>

    </div>

</div>