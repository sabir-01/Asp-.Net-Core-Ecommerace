@model List<OrderDetails>

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Order Details
            </h4>
            <span class="badge bg-light text-dark fs-6">
                Total Orders: @Model.Count
            </span>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Product Id</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th>Total</th>
                            <th width="220">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@order.orderDetails_id</td>
                                <td>@order.quantity</td>
                                <td>@order.price</td>
                                <td>@order.sub_total</td>

                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a href="@Url.Action("updateorderdetail","Admin", new { id = order.orderDetails_id })"
                                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="fa-solid fa-pen me-1"></i> Update
                                        </a>

                                        <a href="@Url.Action("deletePermissionorderdetail","Admin", new { id = order.orderDetails_id })"
                                           class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>