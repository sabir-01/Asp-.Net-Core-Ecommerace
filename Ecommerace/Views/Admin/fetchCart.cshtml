@model List<Carts>

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Cart Details
            </h4>
            <span class="badge bg-light text-dark fs-6">
                Total: @Model.Count
            </span>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle text-center">

                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th>Customer Name</th>
                            <th>Product Quantity</th>
                            <th>Status</th>
                            <th width="220">Option</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var Carts in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@Carts.products.product_name</td>
                                <td>@Carts.customers.customer_name</td>
                                <td>@Carts.product_quantity</td>
                                <td>
                                    @if (Carts.cart_status == 1)
                                    {
                                        <span class="badge bg-success">Order</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">

                                        <a href="@Url.Action("updateCarts","Admin", new { id = Carts.cart_id })"
                                           class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="fa-solid fa-pen me-1"></i> Update
                                        </a>

                                        <a href="@Url.Action("deletePermissionCarts","Admin", new { id = Carts.cart_id })"
                                           class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>