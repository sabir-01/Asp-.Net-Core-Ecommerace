@using System.Text.Json

<style>
    .chart-container {
        height: 350px; /* 🔥 Same height for both */
        position: relative;
        margin-top:10px;
    }
</style>
<div class="container-fluid px-4">
    <h1 class="mt-4 text-center">Admin Dashboard</h1>

    <div class="row mt-4 g-4">

        <!-- Customers -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4" style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-users fa-2x mb-2"></i>
                    <h5>Total Customers</h5>
                    <h2>@ViewBag.TotalCustomers</h2>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4" style="background: linear-gradient(135deg, #1d2671, #c33764); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-shopping-cart fa-2x mb-2"></i>
                    <h5>Total Orders</h5>
                    <h2>@ViewBag.TotalOrders</h2>
                </div>
            </div>
        </div>

        <!-- Order Details -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4" style="background: linear-gradient(135deg, #2b5876, #4e4376); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-clipboard-list fa-2x mb-2"></i>
                    <h5>Order Details</h5>
                    <h2>@ViewBag.TotalOrderDetails</h2>
                </div>
            </div>
        </div>

        <!-- Products -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4" style="background: linear-gradient(135deg, #11998e, #38ef7d); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-box-open fa-2x mb-2"></i>
                    <h5>Total Products</h5>
                    <h2>@ViewBag.TotalProducts</h2>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4 mt-4" style="background: linear-gradient(135deg, #f7971e, #ffd200); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-tags fa-2x mb-2"></i>
                    <h5>Total Categories</h5>
                    <h2>@ViewBag.TotalCategories</h2>
                </div>
            </div>
        </div>

        <!-- Cart -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4 mt-4" style="background: linear-gradient(135deg, #434343, #000000); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-shopping-basket fa-2x mb-2"></i>
                    <h5>Items In Cart</h5>
                    <h2>@ViewBag.TotalCart</h2>
                </div>
            </div>
        </div>

        <!-- Feedback -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4 mt-4" style="background: linear-gradient(135deg, #ff416c, #ff4b2b); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-comments fa-2x mb-2"></i>
                    <h5>User Feedback</h5>
                    <h2>@ViewBag.TotalFeedback</h2>
                </div>
            </div>
        </div>

        <!-- FAQs -->
        <div class="col-md-3">
            <div class="card text-white shadow rounded-4 mt-4" style="background: linear-gradient(135deg, #396afc, #2948ff); transition: transform 0.3s;">
                <div class="card-body text-center">
                    <i class="fas fa-question-circle fa-2x mb-2"></i>
                    <h5>Total FAQs</h5>
                    <h2>@ViewBag.TotalFaqs</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Optional: Add hover effect -->
    <style>
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.3);
        }
    </style>

    <!-- Font Awesome for icons -->
    <div class="row mt-5">

        <!-- Orders Overview Chart -->
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header">
                    <h4>Orders Overview</h4>
                </div>
                <div class="card-body">
                    <canvas id="ordersChart" style="height:300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Products by Category Chart -->
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header">
                    <h4>Products by Category</h4>
                </div>
                <div class="card-body">
                    <canvas id="categoryChart" style="height:300px;"></canvas>
                </div>
            </div>
        </div>


        <!-- Orders per Customer -->

        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h4>Orders per Customer</h4>
                </div>
                <div class="card-body chart-container">
                    <canvas id="orderCustomerDoughnutChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h4>Orders vs Customers</h4>
                </div>
                <div class="card-body chart-container">
                    <canvas id="multiAxisLineChart"></canvas>
                </div>
            </div>
        </div>

    </div>
</div>


<script>
    //////////////////////////////////////
    document.addEventListener("DOMContentLoaded", function () {

        var monthlyOrders = @Html.Raw(JsonSerializer.Serialize(ViewBag.MonthlyOrders));

        var ctx = document.getElementById('ordersChart');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                    'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Orders',
                    data: monthlyOrders
                }]
            }
        });

    });

    //////////////////////////////////////
    document.addEventListener("DOMContentLoaded", function () {

        // Use Newtonsoft.Json or System.Text.Json depending on your setup
        var labels = @Html.Raw(JsonSerializer.Serialize(ViewBag.CategoryNames));
        var data = @Html.Raw(JsonSerializer.Serialize(ViewBag.CategoryCounts));

        var ctx = document.getElementById('categoryChart').getContext('2d');

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Products per Category',
                    data: data,
                    backgroundColor: 'rgba(54, 162, 235, 0.7)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

    });
//////////////////////////////////////
    document.addEventListener("DOMContentLoaded", function () {

        var labels = @Html.Raw(JsonSerializer.Serialize(ViewBag.CustomerNames));
        var ordersData = @Html.Raw(JsonSerializer.Serialize(ViewBag.OrderCounts));

        function generateColors(count) {
            let bgColors = [];
            let borderColors = [];

            for (let i = 0; i < count; i++) {
                let r = Math.floor(Math.random() * 255);
                let g = Math.floor(Math.random() * 255);
                let b = Math.floor(Math.random() * 255);

                bgColors.push(`rgba(${r}, ${g}, ${b}, 0.6)`);
                borderColors.push(`rgba(${r}, ${g}, ${b}, 1)`);
            }

            return { bgColors, borderColors };
        }

        var colors = generateColors(labels.length);

        var ctx = document.getElementById('orderCustomerDoughnutChart').getContext('2d');

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Orders per Customer',
                    data: ordersData,
                    backgroundColor: colors.bgColors,
                    borderColor: colors.borderColors,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '50%',
                plugins: {
                    legend: {
                        position: 'right'
                    }
                }
            }
        });

    });
    //////////////////////////
    document.addEventListener("DOMContentLoaded", function () {

        var labels = @Html.Raw(JsonSerializer.Serialize(ViewBag.CustomerNames));
        var ordersData = @Html.Raw(JsonSerializer.Serialize(ViewBag.OrderCounts));
        var customersData = @Html.Raw(JsonSerializer.Serialize(ViewBag.TotalCustomers));

        var ctx = document.getElementById('multiAxisLineChart').getContext('2d');

        new Chart(ctx, {
            type: 'line', // Line chart
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Orders',
                        data: ordersData,
                        borderColor: 'rgba(54, 162, 235, 1)',
                        backgroundColor: 'rgba(54, 162, 235, 0.2)',
                        yAxisID: 'yOrders',
                        tension: 0.4
                    },
                    {
                        label: 'Customers',
                        data: customersData,
                        borderColor: 'rgba(255, 99, 132, 1)',
                        backgroundColor: 'rgba(255, 99, 132, 0.2)',
                        yAxisID: 'yCustomers',
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                stacked: false,
                scales: {
                    yOrders: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Orders'
                        }
                    },
                    yCustomers: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        beginAtZero: true,
                        grid: {
                            drawOnChartArea: false // avoids overlapping grid lines
                        },
                        title: {
                            display: true,
                            text: 'Customers'
                        }
                    }
                }
            }
        });

    });
        //////////////////////////////////////
</script>