@model Catagory

<div class="container-fluid px-4 mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-danger text-white rounded-top-4 text-center">
            <h4 class="mb-0 text-uppercase" style="letter-spacing:2px;">
                Are You Sure You Want To Delete This Category?
            </h4>
        </div>

        <div class="card-body">

            <div class="row">
                <div class="col-md-2"></div>

                <div class="col-md-8">

                    <ul class="list-group mb-4 shadow-sm">
                        <li class="list-group-item"><strong>Category Id:</strong> @Model.category_id</li>
                        <li class="list-group-item"><strong>Category Name:</strong> @Model.category_name</li>
                    </ul>

                    <div class="d-flex justify-content-center gap-3">
                        <a href="@Url.Action("deletecategory","Admin", new { id = Model.category_id })"
                           class="btn btn-danger btn-lg rounded-pill px-4">
                            <i class="fa-solid fa-trash me-1"></i> Delete Category
                        </a>

                        <a href="@Url.Action("fetchCategory","Admin")"
                           class="btn btn-warning btn-lg rounded-pill px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                        </a>
                    </div>

                </div>

                <div class="col-md-2"></div>
            </div>

        </div>

    </div>

</div>